{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "App",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}/src/app",
      "command": "bun run dev",
      "serverReadyAction": {
        "pattern": "Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Server",
      "request": "launch",
      "type": "debugpy",
      "cwd": "${workspaceFolder}/src/server",
      "module": "fastapi",
      "args": ["dev", "main.py"],
      "jinja": true,
      "autoReload": {
        "enable": true
      },
      "env": {
        "PYDEVD_USE_SYS_MONITORING": "FALSE"
      }
    }
  ],
  "compounds": [
    {
      "name": "App + Server",
      "configurations": ["App", "Server"],
      "stopAll": true
    }
  ]
}
